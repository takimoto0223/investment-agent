# ===== 三菱UFJ eスマート証券 / kabu STATION API =====
# 環境切り替え: "test"=検証(18081) / "live"=本番(18080)
# デフォルトは test: 未設定・誤設定時の実弾発注事故を防ぐため
KABU_ENV=test
# APIパスワード（環境別）: 接続先ポートと同一の判定で自動選択される
KABU_API_PASSWORD_TEST=your_kabu_test_password    # 検証環境(ポート18081)用
KABU_API_PASSWORD_LIVE=your_kabu_live_password    # 本番環境(ポート18080)用
# 後方互換フォールバック: _TEST/_LIVE が未設定の場合のみ使われる（任意）
# KABU_API_PASSWORD=your_kabu_api_password
# 本番(live)で発注系メソッドを呼ぶ場合のみ有効化（通常はコメントアウト）
# KABU_ALLOW_LIVE_ORDER=1
# 個別にURLを上書きしたい場合のみ設定（通常は KABU_ENV で制御）
# KABU_BASE_URL=http://localhost:18080/kabusapi

# ===== Alpaca (米国株) =====
ALPACA_API_KEY=your_alpaca_api_key
ALPACA_SECRET_KEY=your_alpaca_secret_key
ALPACA_BASE_URL=https://paper-api.alpaca.markets  # 本番: https://api.alpaca.markets

# ===== Anthropic Claude API (エージェントLLM) =====
ANTHROPIC_API_KEY=your_anthropic_api_key

# ===== リスク上限設定 =====
MAX_POSITION_SIZE_JPY=500000        # 1銘柄あたりの最大現物保有額（円）
MAX_DAYTRADE_MARGIN_JPY=300000      # 信用デイトレの最大建玉額（円）
MAX_LOSS_PER_DAY_JPY=50000          # 1日の最大損失額（損切りライン）
MAX_US_POSITION_USD=3000            # 米国株1銘柄最大保有額（ドル）

# ===== レポートメール送信 =====
REPORT_FROM_EMAIL=                  # 送信元GmailアドレスJ
REPORT_TO_EMAIL=                    # 送信先メールアドレス
GMAIL_APP_PASSWORD=                 # Gmailアプリパスワード（Googleアカウント設定で発行）
